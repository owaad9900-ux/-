{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with plan details",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Lowercased unique email address"
        },
        "password": {
          "type": "string",
          "description": "Hashed or plain password"
        },
        "name": {
          "type": "string",
          "description": "Human name"
        },
        "planId": {
          "type": "string",
          "enum": ["free", "pro", "royal"],
          "description": "Current active plan"
        },
        "activatedCode": {
          "type": "string",
          "description": "The code used to activate the current plan"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account registration timestamp"
        }
      },
      "required": ["email", "password", "name", "planId", "createdAt"]
    },
    "ActivationCode": {
      "title": "Activation Code",
      "description": "A single-use activation code to upgrade plans",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "The exact code like TEID-OTHMAN-XXXXXXXXX"
        },
        "plan": {
          "type": "string",
          "enum": ["pro", "royal"],
          "description": "Target plan tier to activate"
        },
        "used": {
          "type": "boolean",
          "description": "Whether the code has already been redeemed"
        },
        "usedBy": {
          "type": "string",
          "description": "The email of the user who redeemed it"
        },
        "usedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Redemption timestamp"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Code creation timestamp"
        }
      },
      "required": ["code", "plan", "used", "createdAt"]
    }
  },
  "firestore": {
    "/users/{email}": {
      "schema": "User",
      "description": "User account documents indexed by email address"
    },
    "/activation_codes/{code}": {
      "schema": "ActivationCode",
      "description": "Unused or used activation codes generated by Telegram bot or manually"
    }
  }
}
